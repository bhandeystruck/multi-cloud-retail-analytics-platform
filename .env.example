# ============================================================
# Multi-Cloud Retail Analytics Platform
# 
# Copy to .env for local development:
# cp .env.example .env
#
# ============================================================


# ============================================================
# Application
# ============================================================

APP_ENV=local
APP_NAME=multi-cloud-retail-analytics-platform
LOG_LEVEL=INFO


# ============================================================
# Local Object Storage - MinIO
#
# MinIO is used locally to simulate AWS S3.
# the same ingestion logic can be adapted to real S3.
# ============================================================

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=retail-bronze


# ============================================================
# AWS Configuration
#
# These are placeholders for the real cloud phase.
# Do not fill real values in this file.
# ============================================================

AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REDSHIFT_HOST=your-redshift-cluster.amazonaws.com
AWS_REDSHIFT_PORT=5439
AWS_REDSHIFT_DATABASE=retail_analytics
AWS_REDSHIFT_USER=your_redshift_user
AWS_REDSHIFT_PASSWORD=your_redshift_password


# ============================================================
# GCP Configuration
#
# These are placeholders for the multi-cloud replication phase.
# ============================================================

GCP_PROJECT_ID=your-gcp-project-id
GCP_GCS_BUCKET=your-gcs-bucket-name
GCP_BIGQUERY_DATASET=retail_analytics
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json


# ============================================================
# Local Warehouse Database
#
# We will use PostgreSQL locally to simulate warehouse behavior
# before connecting to Redshift and BigQuery.
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=retail_analytics
POSTGRES_USER=retail_user
POSTGRES_PASSWORD=retail_password


# ============================================================
# FastAPI
# ============================================================

API_HOST=0.0.0.0
API_PORT=8000


# ============================================================
# Airflow
# ============================================================

AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./airflow