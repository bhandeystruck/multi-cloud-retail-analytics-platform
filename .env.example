# ============================================================
# Multi-Cloud Retail Analytics Platform
# Example environment configuration
#
# Copy this file to .env for local development:
#
#   cp .env.example .env
#
# Never commit your real .env file.
# ============================================================


# ============================================================
# Application
# ============================================================

APP_ENV=local
APP_NAME=multi-cloud-retail-analytics-platform
LOG_LEVEL=INFO


# ============================================================
# Local Object Storage - MinIO
#
# MinIO is used locally to simulate AWS S3.
# This allows us to build and test object-storage ingestion
# without paying for cloud resources.
# ============================================================

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=retail-bronze
MINIO_SECURE=false


# ============================================================
# Local PostgreSQL Warehouse Simulation
#
# PostgreSQL is used locally to simulate warehouse behavior.
# Later, this maps conceptually to Redshift and BigQuery.
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=retail_analytics
POSTGRES_USER=retail_user
POSTGRES_PASSWORD=retail_password


# ============================================================
# Airflow
#
# Airflow needs its own metadata database.
# For local development, we use a separate PostgreSQL database
# inside the same PostgreSQL container.
# ============================================================

AIRFLOW_UID=50000
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_FIRSTNAME=Data
AIRFLOW_ADMIN_LASTNAME=Engineer
AIRFLOW_ADMIN_EMAIL=admin@example.com

AIRFLOW_DB=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow


# ============================================================
# FastAPI
# ============================================================

API_HOST=0.0.0.0
API_PORT=8000


# ============================================================
# AWS Placeholder Configuration
#
# These values will be used later when we connect real AWS
# services such as S3, Redshift, EC2, ECS, IAM, and VPC.
# Do not put real secrets in .env.example.
# ============================================================

AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REDSHIFT_HOST=your-redshift-cluster.amazonaws.com
AWS_REDSHIFT_PORT=5439
AWS_REDSHIFT_DATABASE=retail_analytics
AWS_REDSHIFT_USER=your_redshift_user
AWS_REDSHIFT_PASSWORD=your_redshift_password


# ============================================================
# GCP Placeholder Configuration
#
# These values will be used later for GCS and BigQuery.
# Do not put real secrets in .env.example.
# ============================================================

GCP_PROJECT_ID=your-gcp-project-id
GCP_GCS_BUCKET=your-gcs-bucket-name
GCP_BIGQUERY_DATASET=retail_analytics
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json